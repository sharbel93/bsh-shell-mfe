{
  "name": "bsh-shell-mfe",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "concurrently -n shell,mail,calendar -c blue,green,magenta \"ng serve shell --port 4200\" \"ng serve mail --port 4201\" \"ng serve calendar --port 4202\"",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "start:shell": "ng serve shell --port 4200",
    "start:mail": "ng serve mail --port 4201",
    "start:calendar": "ng serve calendar --port 4202",
    "build:all": "ng build shell && ng build mail && ng build calendar"
  },
  "private": true,
  "packageManager": "npm@11.13.0",
  "dependencies": {
    "@angular-architects/native-federation": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "es-module-shims": "^2.8.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.0",
    "@softarc/native-federation-orchestrator": "^4.2.2",
    "concurrently": "^10.0.3",
    "jsdom": "^28.0.0",
    "ng-packagr": "^22.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}